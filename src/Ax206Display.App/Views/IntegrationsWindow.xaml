<Window x:Class="Ax206Display.App.Views.IntegrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ax206Display - Integrations"
        Height="680" Width="520"
        MinHeight="560" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource AppFontFamily}">
    <TabControl Margin="12" Background="{StaticResource SurfaceBrush}">
        <TabItem Header="Proxmox">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="Proxmox VE" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Shows live CPU/memory for VMs and containers as a &quot;System Stat&quot; widget reading in the Widget Designer." TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10"/>

                    <TextBlock Text="Host URL (e.g. https://proxmox.local:8006)" Margin="0,0,0,2"/>
                    <TextBox x:Name="ProxmoxUrlTextBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Username" Margin="0,0,0,2"/>
                    <TextBox x:Name="ProxmoxUsernameTextBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Realm" Margin="0,0,0,2"/>
                    <TextBox x:Name="ProxmoxRealmTextBox" Text="pam" Margin="0,0,0,8"/>

                    <TextBlock Text="Password (leave blank to keep the saved one)" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="ProxmoxPasswordBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Pinned certificate thumbprint (optional - for a self-signed certificate)" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Detect" Padding="10,4" Margin="6,0,0,0" Click="OnProxmoxDetectCertificateClick"/>
                        <TextBox x:Name="ProxmoxThumbprintTextBox"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Test &amp; Save" Padding="12,4" Margin="0,0,8,0" Style="{StaticResource AccentButtonStyle}" Click="OnProxmoxTestAndSaveClick"/>
                        <Button Content="Remove" Padding="12,4" Click="OnProxmoxRemoveClick"/>
                    </StackPanel>
                    <TextBlock x:Name="ProxmoxStatusText" TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Pi-hole">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="Pi-hole" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Shows ads blocked today, DNS queries today, and block percentage as a &quot;System Stat&quot; widget reading." TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Host (e.g. pi.hole or 192.168.1.42 - no http:// or port)" TextWrapping="Wrap" Margin="0,0,0,2"/>
                            <TextBox x:Name="PiHoleHostTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Port" Margin="0,0,0,2"/>
                            <TextBox x:Name="PiHolePortTextBox" Text="80"/>
                        </StackPanel>
                    </Grid>
                    <CheckBox x:Name="PiHoleUseHttpsCheckBox" Content="Use HTTPS" Margin="0,0,0,8"/>

                    <TextBlock Text="App password (Settings -&gt; API -&gt; App Passwords -&gt; Configure app password, leave blank to keep the saved one)" TextWrapping="Wrap" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PiHoleTokenBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Pinned certificate thumbprint (optional - only if using HTTPS with a self-signed certificate)" TextWrapping="Wrap" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Detect" Padding="10,4" Margin="6,0,0,0" Click="OnPiHoleDetectCertificateClick"/>
                        <TextBox x:Name="PiHoleThumbprintTextBox"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Test &amp; Save" Padding="12,4" Margin="0,0,8,0" Style="{StaticResource AccentButtonStyle}" Click="OnPiHoleTestAndSaveClick"/>
                        <Button Content="Remove" Padding="12,4" Click="OnPiHoleRemoveClick"/>
                    </StackPanel>
                    <TextBlock x:Name="PiHoleStatusText" TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="UniFi">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="UniFi" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Shows connected client count and WAN download/upload throughput as a &quot;System Stat&quot; widget reading. Works with both UniFi OS consoles (UDM/UDM Pro/Cloud Key Gen2+) and the classic standalone Network Application - the connection type is detected automatically." TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10"/>

                    <TextBlock Text="Host URL (e.g. https://192.168.1.1 or https://unifi.local:8443)" TextWrapping="Wrap" Margin="0,0,0,2"/>
                    <TextBox x:Name="UniFiUrlTextBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Username" Margin="0,0,0,2"/>
                    <TextBox x:Name="UniFiUsernameTextBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Site" Margin="0,0,0,2"/>
                    <TextBox x:Name="UniFiSiteTextBox" Text="default" Margin="0,0,0,8"/>

                    <TextBlock Text="Password (leave blank to keep the saved one)" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="UniFiPasswordBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Pinned certificate thumbprint (optional - for a self-signed certificate)" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Detect" Padding="10,4" Margin="6,0,0,0" Click="OnUniFiDetectCertificateClick"/>
                        <TextBox x:Name="UniFiThumbprintTextBox"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Test &amp; Save" Padding="12,4" Margin="0,0,8,0" Style="{StaticResource AccentButtonStyle}" Click="OnUniFiTestAndSaveClick"/>
                        <Button Content="Remove" Padding="12,4" Click="OnUniFiRemoveClick"/>
                    </StackPanel>
                    <TextBlock x:Name="UniFiStatusText" TextWrapping="Wrap" Foreground="{StaticResource Text2Brush}"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
