<Window x:Class="Ax206Display.App.Views.WidgetDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Ax206Display - Widget Designer"
        Height="420" Width="640"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"
                   Text="M1 scaffold preview: this renders a clock widget end-to-end through the real compositor and pixel pipeline used to drive a physical display. The full form-based widget editor (add/remove/configure widgets per device) is a later milestone."/>
        <Border DockPanel.Dock="Bottom" Background="Black" Height="320" Width="480" HorizontalAlignment="Center">
            <skia:SKElement x:Name="PreviewElement" PaintSurface="OnPaintSurface"/>
        </Border>
    </DockPanel>
</Window>
